{
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "https://mu63.netlify.app/$1"
        }
    ],
    "headers": [
        {
            "source": "/(.*\\.html)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-cache, no-store, must-revalidate"
                }
            ]
        }
    ]

}

